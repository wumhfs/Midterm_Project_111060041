rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 1. User Profile
    // ==========================================
    match /users/{userId} {
      allow read: if request.auth != null;
      
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // 2. rooms
    // ==========================================
    match /rooms/{roomId} {
      allow create: if request.auth != null;
      
      // 必須是該房間的成員 (members 陣列包含自己的 uid) 才能讀取或修改房間資訊
      allow read, update: if request.auth != null && (request.auth.uid in resource.data.members);

      // ==========================================
      // 3. messages 
      // ==========================================
      match /messages/{messageId} {
        
        function isRoomMember() {
          let roomData = get(/databases/$(database)/documents/rooms/$(roomId)).data;
          return request.auth.uid in roomData.members;
        }

        allow read: if request.auth != null && isRoomMember();
        allow create: if request.auth != null && isRoomMember() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.senderId == request.auth.uid;
      }
    }
  }
}